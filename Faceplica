# Faceplica — aedificatio libsic.a et instrumenta
#
# Usus:
#   make -f Faceplica            — aedifica omnia
#   make -f Faceplica proba      — curre probationes
#   make -f Faceplica purga      — dele omnia aedificata

PREFIX      = /opt/apotheca
FONTES      = sic.c
OBJECTA     = $(FONTES:.c=.o)
BIBLIOTHECA = libsic.a

omnia: $(BIBLIOTHECA) siclint

%.o: %.c sic.h
	ccc $<

$(BIBLIOTHECA): $(OBJECTA)
	ar rcs $@ $^
	@echo "==> $(BIBLIOTHECA) aedificata"

siclint: siclint.o $(BIBLIOTHECA)
	ldi $^
	@echo "==> siclint aedificatum"

proba_prima: proba_prima.o $(BIBLIOTHECA)
	ldi $^

proba: proba_prima
	./proba_prima

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/sic
	install -m 755 siclint $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 sic.h $(PREFIX)/include/sic/

purga:
	rm -f $(OBJECTA) $(BIBLIOTHECA) siclint proba_prima
	rm -f proba_prima.o siclint.o
	rm -rf artifacta

linte:
	insinulint -c sic.c sic.h siclint.c proba_prima.c

.PHONY: omnia colloca proba purga
